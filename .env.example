MOPPA_PUBLIC_PORT=18081

POSTGRES_DB=moppa
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# External source database for S1 scheduled pull task
SOURCE_DB_HOST=192.168.1.222
SOURCE_DB_PORT=5432
SOURCE_DB_NAME=news_event
SOURCE_DB_SCHEMA=public
SOURCE_DB_USER=evt
SOURCE_DB_PASSWORD=eoDErVx4Z5pJ

SOURCE_SYSTEM_NAME=news_event_crawler
SOURCE_FETCH_LIMIT=200
SOURCE_BOOTSTRAP_LIMIT=500
SOURCE_OVERLAP_MINUTES=10

# Set true to run APScheduler pull job in backend
SCHEDULER_ENABLED=true

# Auto review (LLM-based). Keep disabled until below values are set.
AUTO_REVIEW_ENABLED=false
AUTO_REVIEW_CRON=0 * * * *
AUTO_REVIEW_MODEL=GLM-4.6-FP8
AUTO_REVIEW_BASE_URL=
AUTO_REVIEW_API_KEY=
AUTO_REVIEW_BATCH_SIZE=100
AUTO_REVIEW_TIMEOUT_SECONDS=60
LOG_LEVEL=INFO

CORS_ALLOWED_ORIGINS=http://localhost:18081
